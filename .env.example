# Mapbox public token (starts with "pk."). Safe to expose client-side —
# restrict it by URL in the Mapbox account dashboard, not by hiding it.
VITE_MAPBOX_TOKEN=pk.your_public_token_here

# Optional: your own Mapbox Studio style URL once you've retinted the base
# map to match the brand palette in src/config/mapConfig.js. Falls back to
# mapbox://styles/mapbox/light-v11 if omitted.
VITE_MAPBOX_STYLE_URL=mapbox://styles/your-username/your-style-id
